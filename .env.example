# FaaSr Blocks Environment Variables
# Copy this file to .env and fill in your values

# ============================================================================
# Phase 2: Block Builder (LLM for test/code generation)
# ============================================================================

# OpenAI-compatible API settings
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ============================================================================
# Phase 3: Discovery (Embedding & S3 Storage)
# ============================================================================

# S3-compatible storage for embeddings
FAASR_S3_ENDPOINT=https://s3.amazonaws.com
FAASR_S3_ACCESS_KEY=AKIA...
FAASR_S3_SECRET_KEY=...
FAASR_S3_BUCKET=your-bucket-name

# ============================================================================
# Example Configurations
# ============================================================================

# For MinIO (local S3 development):
# FAASR_S3_ENDPOINT=http://localhost:9000
# FAASR_S3_ACCESS_KEY=minioadmin
# FAASR_S3_SECRET_KEY=minioadmin
# FAASR_S3_BUCKET=faasr-blocks

# For Play MinIO (testing):
# FAASR_S3_ENDPOINT=https://play.min.io
# FAASR_S3_ACCESS_KEY=Q3AM3UQ867SPQQA43P2F
# FAASR_S3_SECRET_KEY=zuf+tfteSlswRu7BJ86wekitnifILbZam1KYY3TG
# FAASR_S3_BUCKET=faasr

# ============================================================================
# Optional: Debug
# ============================================================================

# Set to "1" for verbose debug output
# FAASR_BLOCKS_DEBUG=1
